@page "/dashboard"

@inject ITicketService TicketService
<PageTitle>Dashboard</PageTitle>
<a href="/">← Back to Home</a>
<h1>Support Ticket Dashboard</h1>
<div>
    <strong>Total Tickets: @tickets.Count</strong>
</div>

@if (tickets.Count == 0)
{
    <p>No tickets have been submitted yet.</p>
}
else
{
    <div>
        <strong>Total Tickets: @tickets.Count</strong>
    </div>
    <table>
        <thead>
            <tr>
                <th>ID</th>
                <th>Title</th>
                <th>Priority</th>
                <th>Status</th>
                <th>Submitted By</th>
                <th>Created</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var ticket in tickets)
            {
                <tr>
                    <td><a href="/ticket/@ticket.Id">@ticket.Title</a></td>
                    <td>@ticket.Title</td>
                    <td>@ticket.Priority</td>
                    <td>@ticket.Status</td>
                    <td>@ticket.SubmittedBy</td>
                    <td>@ticket.CreatedAt.ToString("g")</td>
                </tr>
            }
        </tbody>
    </table>
}


@code {
    private List<Ticket> tickets = new();

    protected override void OnInitialized()
    {
        tickets = TicketService.GetAllTickets();
    }
}
