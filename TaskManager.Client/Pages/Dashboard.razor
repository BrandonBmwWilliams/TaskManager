@page "/dashboard"

<h3>Dashboard</h3>
<div>
    <strong>Total Tickets: @tickets.Count</strong>
</div>

@if (tickets.Count == 0)
{
    <p>No tickets have been submitted yet.</p>
}
else
{
    <div>
        <strong>Total Tickets: @tickets.Count</strong>
    </div>
    <table>
        <thead>
            <tr>
                <th>ID</th>
                <th>Title</th>
                <th>Priority</th>
                <th>Status</th>
                <th>Submitted By</th>
                <th>Created</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var ticket in tickets)
            {
                <tr>
                    <td>@ticket.Id</td>
                    <td>@ticket.Title</td>
                    <td>@ticket.Priority</td>
                    <td>@ticket.Status</td>
                    <td>@ticket.SubmittedBy</td>
                    <td>@ticket.CreatedAt.ToString("g")</td>
                </tr>
            }
        </tbody>
    </table>
}

@code
{
    private List<Ticket> tickets = new()
    {
        new Ticket {
            Id = 1,
            Title = "Printer not working",
            Description = "3rd floor HP LaserJet showing error",
            Priority = TicketPriority.High,
            SubmittedBy = "John Smith",
            CreatedAt = DateTime.Now.AddHours(-2)
        },
        new Ticket {
            Id = 2,
            Title = "Need VPN access",
            Description = "New employee needs VPN setup",
            Priority = TicketPriority.Medium,
            SubmittedBy = "Jane Doe",
            CreatedAt = DateTime.Now.AddDays(-1)
        },
        new Ticket {
            Id = 3,
            Title = "Email server down",
            Description = "No one in accounting can send emails",
            Priority = TicketPriority.Critical,
            SubmittedBy = "Bob Wilson",
            CreatedAt = DateTime.Now.AddMinutes(-30)
        }
    };
}
