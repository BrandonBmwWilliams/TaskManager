@page "/submit"
@inject ITicketService TicketService
<PageTitle>Submit a Ticket</PageTitle>
<a href="/">← Back to Home</a>
<h1>Submit a Support Ticket</h1>

<EditForm Model="newTicket" OnValidSubmit="HandleSubmit">
    <DataAnnotationsValidator />
    <ValidationSummary />
    <div>
        <label>Title</label>
        <InputText @bind-Value="newTicket.Title" />
        <ValidationMessage For="() => newTicket.Title" />
    </div>
    <div>
        <label>Description</label>
        <InputTextArea @bind-Value="newTicket.Description" />
        <ValidationMessage For="() => newTicket.Description" />
    </div>
    <div>
        <label>Priority</label>
        <InputSelect @bind-Value="newTicket.Priority">
            @foreach (var priority in Enum.GetValues<TicketPriority>())
            {
                <option value="@priority">@priority</option>
            }
        </InputSelect>
    </div>
    <div>
        <label>Your Name</label>
        <InputText @bind-Value="newTicket.SubmittedBy" />
        <ValidationMessage For="() => newTicket.SubmittedBy" />
    </div>
    <button type="submit">Submit Ticket</button>
</EditForm>
@if (isSubmitted)
{
    <div>
        <h3>Ticket Submitted!</h3>
        <p>Title: @submittedTitle</p>
        
    </div>
}

@code
{
    private Ticket newTicket = new();
    private bool isSubmitted = false;
    private string submittedTitle = "";

    private void HandleSubmit()
    {
        submittedTitle = newTicket.Title;
        TicketService.AddTicket(newTicket);
        newTicket = new Ticket();
        isSubmitted = true;
    }
}
